{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": [
    "chromaflow"
  ],
  "ios": {
    "iosModuleName": "NitroChromaflow"
  },
  "android": {
    "androidNamespace": [
      "chromaflow"
    ],
    "androidCxxLibName": "NitroChromaflow"
  },
  "autolinking": {
    "ChromaFlow": {
      "all": {
        "language": "c++",
        "implementationClassName": "HybridChromaFlow"
      }
    }
  },
  "ignorePaths": [
    "**/node_modules"
  ]
}
